{
  "title": "NexusPlay - Vue d'ensemble",
  "uid": "nexusplay-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Nombre de pods par Deployment",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas{namespace=\"nexusplay\"}",
          "legendFormat": "{{deployment}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Autoscaling HPA (courant / souhaite / max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"nexusplay\"}",
          "legendFormat": "{{horizontalpodautoscaler}} - courant"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"nexusplay\"}",
          "legendFormat": "{{horizontalpodautoscaler}} - souhaite"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"nexusplay\"}",
          "legendFormat": "{{horizontalpodautoscaler}} - max"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latence des requetes HTTP (p95, leaderboard-service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"nexusplay\"}[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  }
}
